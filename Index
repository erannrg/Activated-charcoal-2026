  { drug:"Venlafaxine",                                        minDose:"25 mg/kg",                               form:"IR",    strong:"0-0.5",            weak:"0.5-2",              adacGrade:null,                    adac:"Not Recommended (D)" },
  { drug:"Venlafaxine",                                        minDose:"25 mg/kg",                               form:"MR",    strong:"0-1",              weak:"1-3",                adacGrade:null,                    adac:"Not Recommended (D)" },
  { drug:"Warfarin",                                           minDose:"0.7 mg/kg",                              form:"Any",   strong:"0-1",              weak:null,                 adacGrade:null,                    adac:"Not Recommended (D)" },
];

// ─────────────────────────────────────────────
// HELPERS
// ─────────────────────────────────────────────

// Parse hour range like "0-2", "0-0.5" → {lo, hi}
function parseHourRange(s) {
  if (!s || typeof s !== "string") return null;
  s = s.trim();
  if (s.toLowerCase().includes("not recommended")) return null;
  const m = s.match(/^([\d.]+)\s*-\s*([\d.]+)$/);
  if (m) return { lo: parseFloat(m[1]), hi: parseFloat(m[2]) };
  return null;
}

// Parse a dose string and convert to a standard comparable value (mg or mg/kg)
// Returns { value, unit } for display
function parseThreshold(str, weightKg) {
  if (!str || typeof str !== "string") return null;
  str = str.trim();

  const lower = str.toLowerCase();
  if (lower.includes("not recommended") || lower === "any dose") return { special: lower.includes("not recommended") ? "not_rec" : "any_dose" };

  // Seeds
  const seedsM = str.match(/([\d.]+)\s*seeds?/i);
  if (seedsM) return { value: parseFloat(seedsM[1]), unit: "seeds", raw: str };

  // µg/kg or mcg/kg
  const ugkgM = str.match(/([\d.]+)\s*(µg\/kg|mcg\/kg|ug\/kg)/i);
  if (ugkgM) return { value: parseFloat(ugkgM[1]), unit: "mcg/kg", raw: str };

  // mg/kg
  const mgkgM = str.match(/([\d.]+)\s*mg\/kg/i);
  if (mgkgM) return { value: parseFloat(mgkgM[1]), unit: "mg/kg", raw: str };

  // g
  const gM = str.match(/([\d.]+)\s*g\b/i);
  if (gM) return { value: parseFloat(gM[1]) * 1000, unit: "mg", raw: str };

  // mg
  const mgM = str.match(/([\d.]+)\s*mg/i);
  if (mgM) return { value: parseFloat(mgM[1]), unit: "mg", raw: str };

  // TD
  const tdM = str.match(/([\d.]+)\s*TD/i);
  if (tdM) return { value: parseFloat(tdM[1]), unit: "TD", raw: str };

  return null;
}

// Convert user's entered dose to threshold's unit, returns mg equivalent or comparable value
// Returns null if can't compare
function normalizeDose(doseVal, doseUnit, threshObj, weightKg) {
  if (!threshObj || threshObj.special) return null;
  const tu = threshObj.unit;
  const dv = parseFloat(doseVal);
  if (isNaN(dv)) return null;

  // same unit
  if (doseUnit === tu) return { entered: dv, threshold: threshObj.value };

  // seeds vs seeds
  if (tu === "seeds" && doseUnit === "seeds") return { entered: dv, threshold: threshObj.value };

  // TD vs TD
  if (tu === "TD" && doseUnit === "TD") return { entered: dv, threshold: threshObj.value };

  const w = parseFloat(weightKg);

  // mg/kg threshold: user entered mg → divide by weight
  if (tu === "mg/kg" && doseUnit === "mg" && w > 0) return { entered: dv / w, threshold: threshObj.value };
  // mg/kg threshold: user entered g → convert to mg then divide
  if (tu === "mg/kg" && doseUnit === "g" && w > 0) return { entered: (dv * 1000) / w, threshold: threshObj.value };
  // mg/kg threshold: user entered mg/kg
  if (tu === "mg/kg" && doseUnit === "mg/kg") return { entered: dv, threshold: threshObj.value };

  // mcg/kg threshold: user entered mcg → divide by weight
  if (tu === "mcg/kg" && doseUnit === "mcg" && w > 0) return { entered: dv / w, threshold: threshObj.value };
  if (tu === "mcg/kg" && doseUnit === "mcg/kg") return { entered: dv, threshold: threshObj.value };

  // mg threshold: user entered mg/kg → multiply by weight
  if (tu === "mg" && doseUnit === "mg/kg" && w > 0) return { entered: dv * w, threshold: threshObj.value };
  if (tu === "mg" && doseUnit === "g") return { entered: dv * 1000, threshold: threshObj.value };
  if (tu === "mg" && doseUnit === "mg") return { entered: dv, threshold: threshObj.value };

  return null; // incompatible units
}

// Parse ADAC threshold (column G) into a comparable object
// Returns { value, unit, grade, str }
function parseAdacThreshold(str) {
  if (!str || typeof str !== "string") return null;
  str = str.trim();
  const lower = str.toLowerCase();
  if (lower.includes("not recommended")) return { notRec: true, grade: extractGrade(str) };
  if (lower === "suggest (d)") return { suggest: true, grade: "D" };

  // e.g. ">50mg/kg Strong", ">400mg/kg", "0.7mg/kg Weak", "5TD Weak", ">350mg/kg Strong"
  const gradeMatch = str.match(/(Strong|Weak)/i);
  const grade = gradeMatch ? gradeMatch[1] : null;

  const mgkgM = str.match(/([\d.]+)\s*mg\/kg/i);
  if (mgkgM) return { value: parseFloat(mgkgM[1]), unit: "mg/kg", grade, raw: str };

  const mgkgKM = str.match(/([\d.]+)\s*mg\/Kg/i);
  if (mgkgKM) return { value: parseFloat(mgkgKM[1]), unit: "mg/kg", grade, raw: str };

  const tdM = str.match(/([\d.]+)\s*TD/i);
  if (tdM) return { value: parseFloat(tdM[1]), unit: "TD", grade, raw: str };

  const mgM = str.match(/([\d.]+)\s*mg/i);
  if (mgM) return { value: parseFloat(mgM[1]), unit: "mg", grade, raw: str };

  return null;
}

function extractGrade(str) {
  if (!str) return null;
  const m = str.match(/\(([A-D])\)/);
  return m ? m[1] : null;
}

// ─────────────────────────────────────────────
// UI INIT
// ─────────────────────────────────────────────
function updateRow(id) {
  const chk = document.getElementById("chk-" + id);
  const row = document.getElementById("row-" + id);
  row.classList.toggle("checked", chk.checked);
}

// Build unique drug list
const drugNames = [...new Set(RAW_DATA.map(r => r.drug))].sort();

window.onload = function () {
  const sel = document.getElementById("sel-drug");
  drugNames.forEach(name => {
    const opt = document.createElement("option");
    opt.value = name;
    opt.textContent = name;
    sel.appendChild(opt);
  });
};

function onDrugChange() {
  const drug = document.getElementById("sel-drug").value;
  const formField = document.getElementById("form-field");
  const selForm = document.getElementById("sel-form");
  document.getElementById("drug-info").style.display = "none";
  document.getElementById("result-panel").style.display = "none";

  if (!drug) { formField.style.display = "none"; return; }

  const rows = RAW_DATA.filter(r => r.drug === drug);
  const forms = [...new Set(rows.map(r => r.form))];

  selForm.innerHTML = '<option value="">— Select formulation —</option>';
  if (forms.length === 1 && (forms[0] === "Any" || forms[0] === "IR/MR")) {
    selForm.innerHTML = `<option value="${forms[0]}">${forms[0]}</option>`;
    formField.style.display = "block";
    selForm.value = forms[0];
    onFormChange();
  } else {
    forms.forEach(f => {
      const opt = document.createElement("option");
      opt.value = f;
      opt.textContent = f;
      selForm.appendChild(opt);
    });
    formField.style.display = "block";
  }
}

function onFormChange() {
  const drug = document.getElementById("sel-drug").value;
  const form = document.getElementById("sel-form").value;
  document.getElementById("result-panel").style.display = "none";
  if (!drug || !form) { document.getElementById("drug-info").style.display = "none"; return; }

  const row = RAW_DATA.find(r => r.drug === drug && r.form === form);
  if (!row) return;

  const infoBar = document.getElementById("drug-info");
  infoBar.style.display = "block";
  infoBar.innerHTML = `<span>Threshold:</span> ${row.minDose} &nbsp;|&nbsp; <span>Formulation:</span> ${row.form}`;
}

// ─────────────────────────────────────────────
// MAIN EVALUATE LOGIC
// ─────────────────────────────────────────────
function runEvaluation() {
  const airway = document.getElementById("chk-airway").checked;
  const bowel  = document.getElementById("chk-bowel").checked;
  const drug   = document.getElementById("sel-drug").value;
  const form   = document.getElementById("sel-form").value;
  const doseRaw = document.getElementById("inp-dose").value.trim();
  const doseUnit = document.getElementById("sel-unit").value;
  const weight  = document.getElementById("inp-weight").value.trim();
  const hoursRaw = document.getElementById("inp-hours").value.trim();

  const panel = document.getElementById("result-panel");
  const resSafety = document.getElementById("result-safety");
  const resAC     = document.getElementById("result-ac");
  const resADAC   = document.getElementById("result-adac");

  panel.style.display = "block";
  resSafety.innerHTML = "";
  resAC.innerHTML     = "";
  resADAC.innerHTML   = "";

  // ── STEP 1: Safety checks ──
  if (!airway || !bowel) {
    const missing = [];
    if (!airway) missing.push("Protected Airway");
    if (!bowel)  missing.push("No Signs of Bowel Obstruction/Perforation");
    resSafety.innerHTML = resultBox("not-rec", "⛔ Safety Check Failed",
      "Activated Charcoal: <strong>NOT RECOMMENDED</strong>",
      "Required condition(s) not confirmed: " + missing.join(", "));
    return;
  }

  // ── Drug must be selected ──
  if (!drug || !form) {
    resSafety.innerHTML = resultBox("not-rec", "⚠️ Input Required", "Please select a drug and formulation.", "");
    return;
  }

  const row = RAW_DATA.find(r => r.drug === drug && r.form === form);
  if (!row) {
    resSafety.innerHTML = resultBox("not-rec", "⚠️ Data Error", "Could not find data for selected combination.", "");
    return;
  }

  const weightKg = parseFloat(weight);
  const hours    = hoursRaw !== "" ? parseFloat(hoursRaw) : null;

  // ── STEP 4: Dose threshold check ──
  const threshObj = parseThreshold(row.minDose, weightKg);
  let aboveThreshold = false;
  let threshNote = "";

  if (threshObj && threshObj.special === "not_rec") {
    // Drug is never recommended regardless of dose
    resAC.innerHTML = resultBox("not-rec", "⛔ Activated Charcoal",
      "NOT RECOMMENDED",
      `This agent (${drug}) is not an indication for activated charcoal regardless of dose.`);
    resADAC.innerHTML = resultBox("adac-no", "Additional Dose AC", "Not Recommended", "");
    return;
  }

  if (threshObj && threshObj.special === "any_dose") {
    // Any dose qualifies — proceed without threshold check
    aboveThreshold = false;
    threshNote = "Any dose qualifies for consideration.";
  } else if (doseRaw === "") {
    // No dose entered → treat as exceeding threshold
    aboveThreshold = true;
    threshNote = "No dose entered — treated as exceeding the threshold.";
  } else {
    // Try to normalize and compare
    const cmp = normalizeDose(doseRaw, doseUnit, threshObj, weightKg);
    if (cmp === null) {
      // Incompatible units — can't compare, warn but allow
      threshNote = `Unable to compare dose units (entered: ${doseUnit}, threshold: ${threshObj ? threshObj.unit : "?"}) — verify manually. Threshold: ${row.minDose}.`;
      aboveThreshold = false; // let it proceed with warning
    } else {
      if (cmp.entered < cmp.threshold) {
        aboveThreshold = true;
        threshNote = `Dose ${doseRaw} ${doseUnit} is below the threshold (${row.minDose}). AC not indicated based on dose.`;
      } else {
        threshNote = `Dose ${doseRaw} ${doseUnit} meets or exceeds threshold (${row.minDose}).`;
      }
    }
  }

  if (aboveThreshold) {
    resAC.innerHTML = resultBox("not-rec", "⛔ Activated Charcoal",
      "NOT RECOMMENDED",
      threshNote);
    resADAC.innerHTML = resultBox("adac-no", "Additional Dose AC", "Not Recommended", "");
    return;
  }

  // ── Hours check ──
  if (hours === null || isNaN(hours)) {
    resSafety.innerHTML = resultBox("not-rec", "⚠️ Input Required",
      "Please enter hours since ingestion.", "");
    return;
  }

  // ── STEPS 5 & 6: Time window check ──
  const strongRange = parseHourRange(row.strong);
  const weakRange   = parseHourRange(row.weak);

  let acResult = "not_rec";
  let acLabel  = "";
  let acClass  = "not-rec";

  // Check if the col itself says "Not Recommended" even without range
  const strongText = (row.strong || "").trim().toLowerCase();
  const weakText   = (row.weak   || "").trim().toLowerCase();

  if (strongRange && hours >= strongRange.lo && hours <= strongRange.hi) {
    acResult = "strong";
    acLabel  = "✅ Activated Charcoal Recommended – STRONG";
    acClass  = "strong";
  } else if (weakRange && hours >= weakRange.lo && hours <= weakRange.hi) {
    acResult = "weak";
    acLabel  = "⚠️ Activated Charcoal Recommended – WEAK";
    acClass  = "weak";
  } else {
    acResult = "not_rec";
    acLabel  = "⛔ Activated Charcoal NOT RECOMMENDED";
    acClass  = "not-rec";
  }

  const timeDetail = `Hours since ingestion: ${hours}h | Strong window: ${row.strong || "—"} | Weak window: ${row.weak || "—"}`;
  resAC.innerHTML = resultBox(acClass, acResult === "strong" ? "Strong Recommendation" : acResult === "weak" ? "Weak Recommendation" : "Not Recommended",
    acLabel, timeDetail + (threshNote ? " | " + threshNote : ""));

  // ── STEPS 7 & 8: ADAC check ──
  if (acResult === "strong" || acResult === "weak") {
    const adacObj = parseAdacThreshold(row.adac);

    if (!adacObj) {
      resADAC.innerHTML = resultBox("adac-no", "Additional Dose Activated Charcoal", "Not Recommended", "No ADAC threshold data.");
    } else if (adacObj.notRec) {
      resADAC.innerHTML = resultBox("adac-no", "Additional Dose Activated Charcoal",
        `Not Recommended (Grade ${adacObj.grade || "D"})`, row.adac);
    } else if (adacObj.suggest) {
      // Dapsone has "Suggest (D)"
      resADAC.innerHTML = resultBox("adac-yes", "Additional Dose Activated Charcoal",
        "Suggested — Grade D", row.adac);
    } else {
      // Compare entered dose against ADAC threshold
      const adacCmp = normalizeDose(doseRaw, doseUnit, adacObj, weightKg);
      if (doseRaw === "" || adacCmp === null) {
        resADAC.innerHTML = resultBox("adac-no", "Additional Dose Activated Charcoal",
          "Not Recommended", "Could not compare dose against ADAC threshold (" + row.adac + ") — verify manually.");
      } else if (adacCmp.entered >= adacCmp.threshold) {
        const grade = adacObj.grade || "";
        resADAC.innerHTML = resultBox("adac-yes", "Additional Dose Activated Charcoal",
          `✅ Recommended${grade ? " – " + grade + " (Strength of recommendation)" : ""}`,
          `Dose ${doseRaw} ${doseUnit} exceeds ADAC threshold: ${row.adac}`);
      } else {
        resADAC.innerHTML = resultBox("adac-no", "Additional Dose Activated Charcoal",
          "Not Recommended",
          `Dose ${doseRaw} ${doseUnit} is below ADAC threshold: ${row.adac}`);
      }
    }
  } else {
    resADAC.innerHTML = resultBox("adac-no", "Additional Dose Activated Charcoal",
      "Not Applicable", "AC is not recommended; ADAC assessment not applicable.");
  }
}

function resultBox(cls, label, value, detail) {
  return `<div class="result-box ${cls}">
    <div class="label">${label}</div>
    <div class="value">${value}</div>
    ${detail ? `<div class="detail">${detail}</div>` : ""}
  </div>`;
}

function resetAll() {
  document.getElementById("chk-airway").checked = false;
  document.getElementById("chk-bowel").checked  = false;
  updateRow("airway");
  updateRow("bowel");
  document.getElementById("sel-drug").value  = "";
  document.getElementById("sel-form").innerHTML = '<option value="">— Select formulation —</option>';
  document.getElementById("form-field").style.display = "none";
  document.getElementById("drug-info").style.display = "none";
  document.getElementById("inp-dose").value   = "";
  document.getElementById("inp-weight").value = "";
  document.getElementById("inp-hours").value  = "";
  document.getElementById("sel-unit").value   = "mg";
  document.getElementById("result-panel").style.display = "none";
}
</script>

  .field select:focus, .field input:focus { outline: none; border-color: #2b6cb0; box-shadow: 0 0 0 3px rgba(43,108,176,0.12); }

  .dose-row { display: flex; gap: 10px; }
  .dose-row .field:first-child { flex: 2; }
  .dose-row .field:last-child { flex: 1; }

  /* Result panel */
  #result-panel { display: none; }
  .result-box {
    border-radius: 10px;
    padding: 16px 18px;
    margin-bottom: 12px;
    border-left: 5px solid;
  }
  .result-box.not-rec { background: #fff5f5; border-color: #e53e3e; }
  .result-box.strong { background: #f0fff4; border-color: #38a169; }
  .result-box.weak { background: #ebf8ff; border-color: #3182ce; }
  .result-box.adac-yes { background: #ebf4ff; border-color: #2b6cb0; }
  .result-box.adac-no { background: #f7fafc; border-color: #a0aec0; }


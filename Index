  .not-rec .value { color: #c53030; }
  .strong .label { color: #276749; }
  .strong .value { color: #276749; }
  .weak .label { color: #2c5282; }
  .weak .value { color: #2c5282; }
  .adac-yes .label { color: #2c5282; }
  .adac-yes .value { color: #2c5282; }
  .adac-no .value { color: #4a5568; }


<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>AC Decision Support</title>
    <style>
        body { font-family: sans-serif; padding: 20px; }
        .container { max-width: 600px; margin: auto; padding: 20px; border: 1px solid #ccc; }
        input, select { width: 100%; margin: 10px 0; padding: 10px; }
        .res { padding: 15px; margin-top: 20px; background: #eee; font-weight: bold; }
    </style>
</head>
<body>
<div class="container">
    <h2>AC Decision Support</h2>
    <label><input type="checkbox" id="c1"> Protected Airway</label><br>
    <label><input type="checkbox" id="c2"> No signs of bowel obstruction</label>
    <select id="poisonSelect" onchange="updateFormulations()"><option>Select Drug</option></select>
    <select id="formSelect"><option>Select Formulation</option></select>
    <input type="number" id="doseInput" placeholder="Enter numeric dose (e.g., 200)">
    <input type="number" id="hours" placeholder="Hours from ingestion">
    <button onclick="calculate()">Get Recommendation</button>
    <div id="result" class="res" style="display:none;"></div>
</div>

<script>
// Data structure
const data = [
  {"Poison": "Acetaminophen", "Threshold": 200, "Formulation": "IR", "Strong": [0,2], "Weak": [2,4], "ADAC": 350},
  {"Poison": "Acetaminophen", "Threshold": 200, "Formulation": "MR", "Strong": [0,5], "Weak": [5,6], "ADAC": 300},
  {"Poison": "Carbamazepine", "Threshold": 25, "Formulation": "IR", "Strong": [0,2], "Weak": [2,3], "ADAC": 50},
  {"Poison": "Carbamazepine", "Threshold": 25, "Formulation": "MR", "Strong": [0,3], "Weak": [3,4], "ADAC": 40}
  // ... Paste the rest of your 78 rows here in this exact format ...
];

function calculate() {
    const res = document.getElementById('result');
    const dVal = parseFloat(document.getElementById('doseInput').value);
    const h = parseFloat(document.getElementById('hours').value);
    const drug = JSON.parse(document.getElementById('formSelect').value);

    console.log("Checking:", drug.Poison, "Dose:", dVal, "Hours:", h);

    if(!document.getElementById('c1').checked || !document.getElementById('c2').checked) {
        res.innerHTML = "Not recommended (Safety check fail)";
    } else if (dVal < drug.Threshold) {
        res.innerHTML = "Not Recommended (Below threshold)";
    } else if (h >= drug.Strong[0] && h <= drug.Strong[1]) {
        res.innerHTML = "Recommended – Strong" + (dVal > drug.ADAC ? "<br>+ Add ADAC" : "");
    } else if (h >= drug.Weak[0] && h <= drug.Weak[1]) {
        res.innerHTML = "Recommended – Weak" + (dVal > drug.ADAC ? "<br>+ Add ADAC" : "");
    } else {
        res.innerHTML = "Not Recommended (Time limit)";
    }
    res.style.display = "block";
}
</script>
</body>
</html>

<header>
  <h1>🏥 Activated Charcoal Decision Support</h1>
  <p>Clinical decision aid for AC administration in acute poisoning</p>
</header>
<div class="warning-banner">
  ⚠️ FOR CLINICAL USE BY TRAINED PROFESSIONALS ONLY — Always consult Poison Control
</div>

<div class="container">

  <!-- STEP 1: Safety Checks -->
  <div class="card">
    <h2><span class="badge">1</span> Mandatory Safety Checks</h2>
    <div class="safety-row" id="row-airway">
      <input type="checkbox" id="chk-airway" onchange="updateRow('airway')">
      <label for="chk-airway">
        Protected Airway
        <div class="sub">Patient is able to protect their own airway or airway is secured</div>
      </label>
    </div>
    <div class="safety-row" id="row-bowel">
      <input type="checkbox" id="chk-bowel" onchange="updateRow('bowel')">
      <label for="chk-bowel">
        No Signs of Bowel Obstruction / Perforation
        <div class="sub">No clinical or radiological evidence of obstruction or perforation</div>
      </label>
    </div>
  </div>

  <!-- STEP 2: Drug Selection -->
  <div class="card">
    <h2><span class="badge">2</span> Drug / Poison</h2>
    <div class="field">
      <label>Select Drug / Poison</label>
      <select id="sel-drug" onchange="onDrugChange()">
        <option value="">— Select a drug —</option>
      </select>
    </div>

    <!-- STEP 3: Formulation -->
    <div class="field" id="form-field" style="display:none;">
      <label>Formulation</label>
      <select id="sel-form" onchange="onFormChange()">
        <option value="">— Select formulation —</option>
      </select>
    </div>

    <div class="drug-info-bar" id="drug-info"></div>
  </div>

  <!-- STEP 4: Dose -->
  <div class="card">
    <h2><span class="badge">3</span> Dose &amp; Patient</h2>
    <div class="dose-row">
      <div class="field">
        <label>Ingested Dose</label>
        <input type="number" id="inp-dose" min="0" step="any" placeholder="Enter dose (leave blank = exceeds threshold)">
      </div>
      <div class="field">
        <label>Unit</label>
        <select id="sel-unit">
          <option value="mg">mg</option>
          <option value="mcg">microgram (µg)</option>
          <option value="g">g</option>
          <option value="mg/kg">mg/kg</option>
          <option value="mcg/kg">µg/kg</option>
          <option value="TD">TD (Therapeutic Doses)</option>
          <option value="seeds">seeds</option>
        </select>
      </div>
    </div>
    <div class="field">
      <label>Patient Weight (kg)</label>
      <input type="number" id="inp-weight" min="1" step="0.1" placeholder="e.g. 70">
    </div>
    <div class="field">
      <label>Hours Since Ingestion</label>
      <input type="number" id="inp-hours" min="0" step="0.5" placeholder="e.g. 1.5">
    </div>
  </div>

  <!-- Evaluate Button -->
  <button class="btn-eval" onclick="runEvaluation()">⚡ Evaluate</button>
  <button class="btn-reset" onclick="resetAll()">↺ Reset</button>

  <!-- Result Panel -->
  <div id="result-panel" class="card" style="margin-top:18px;">
    <h2>📋 Result</h2>
    <div id="result-safety"></div>
    <div id="result-ac"></div>
    <div id="result-adac"></div>
  </div>

</div>
<footer>This tool is a clinical decision aid only. Not a substitute for clinical judgment. Version 1.0</footer>


const poisonSelect = document.getElementById('poisonSelect');
const poisons = [...new Set(data.map(d => d.Poison))];
poisons.forEach(p => {
    let opt = document.createElement('option');
    opt.value = p; opt.innerHTML = p;
    poisonSelect.appendChild(opt);
});

function updateFormulations() {
    const formSelect = document.getElementById('formSelect');
    formSelect.innerHTML = '<option>Select Formulation</option>';
    data.filter(d => d.Poison === poisonSelect.value).forEach(d => {
        let opt = document.createElement('option');
        opt.value = JSON.stringify(d);
        opt.innerHTML = d.Formulation;
        formSelect.appendChild(opt);
    });
}

function calculate() {
    const res = document.getElementById('result');
    
    // 1. Mandatory Safety Checks
    if(!document.getElementById('c1').checked || !document.getElementById('c2').checked) {
        res.innerHTML = "Not recommended (Safety checks failed)";
        res.style.display = "block"; return;
    }
    
    // Get inputs
    const drug = JSON.parse(document.getElementById('formSelect').value);
    const h = parseFloat(document.getElementById('hours').value);
    const dVal = parseFloat(document.getElementById('doseInput').value);

    // Helper to check if a string is a numeric range like "0-2"
    function isInRange(timeStr, hours) {
        if (!timeStr || typeof timeStr !== 'string' || !timeStr.includes('-')) return false;
        const [start, end] = timeStr.split('-').map(Number);
        return hours >= start && hours <= end;
    }

    let output = "Recommendation: ";
    
    // 2. Time/Recommendation Logic
    if (isInRange(drug.StrongTime, h)) {
        output += "Activated Charcoal Recommended – Strong";
        // ADAC Check
        if (dVal > parseFloat(drug.ADAC)) output += "<br>Additional dose activated charcoal Recommended (Strong)";
    } 
    else if (isInRange(drug.WeakTime, h)) {
        output += "Activated Charcoal Recommended – Weak";
        // ADAC Check
        if (dVal > parseFloat(drug.ADAC)) output += "<br>Additional dose activated charcoal Recommended (Weak)";
    } 
    else {
        output += "Not Recommended";
    }

    res.innerHTML = output;
    res.style.display = "block";
}

}
